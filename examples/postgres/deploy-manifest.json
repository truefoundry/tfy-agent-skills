{
  "manifest": {
    "name": "postgres-demo",
    "type": "helm",
    "source": {
      "type": "oci-repo",
      "oci_chart_url": "oci://registry-1.docker.io/bitnamicharts/postgresql",
      "version": "16.4.1"
    },
    "values": {
      "auth": {
        "_comment": "TODO: Replace with a strong password or use TrueFoundry secrets",
        "postgresPassword": "CHANGE_ME_TO_A_STRONG_PASSWORD",
        "database": "demodb"
      },
      "primary": {
        "persistence": {
          "enabled": true,
          "size": "5Gi"
        },
        "resources": {
          "requests": { "cpu": "250m", "memory": "256Mi" },
          "limits": { "cpu": "500m", "memory": "512Mi" }
        }
      }
    }
  },
  "_comment": "TODO: Replace workspaceId with your workspace ID from the TrueFoundry dashboard",
  "workspaceId": "<your-workspace-id>"
}
