{
  "manifest": {
    "name": "qdrant-demo",
    "type": "helm",
    "source": {
      "type": "helm-repo",
      "repo_url": "https://qdrant.github.io/qdrant-helm",
      "chart": "qdrant",
      "version": "1.12.5"
    },
    "values": {
      "persistence": {
        "enabled": true,
        "size": "5Gi"
      },
      "resources": {
        "requests": { "cpu": "250m", "memory": "512Mi" },
        "limits": { "cpu": "500m", "memory": "1Gi" }
      },
      "service": {
        "type": "ClusterIP"
      }
    },
    "_comment": "TODO: Replace workspace_fqn with your workspace (e.g. cluster-id:workspace-name)",
    "workspace_fqn": "<cluster-id>:<workspace-name>"
  },
  "_comment": "TODO: Replace workspaceId with your workspace ID from the TrueFoundry dashboard",
  "workspaceId": "<your-workspace-id>"
}
